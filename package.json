{
  "name": "ferride",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @ferride/ferride dev",
    "build": "pnpm --filter @ferride/ferride build",
    "check:unused": "knip",
    "format": "prettier --write .",
    "lint": "pnpm -r lint",
    "preview": "pnpm --filter @ferride/ferride preview",
    "tauri": "pnpm --filter @ferride/ferride tauri"
  },
  "devDependencies": {
    "knip": "^6.24.0",
    "prettier": "^3.9.4",
    "prettier-plugin-classnames": "^0.10.4",
    "prettier-plugin-merge": "^0.10.1",
    "prettier-plugin-tailwindcss": "^0.8.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.0.0"
    }
  }
}
