{
  "name": "ferride",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "build:web": "turbo run build:web",
    "build:linux": "turbo run build:linux",
    "build:win64": "turbo run build:win64",
    "check": "turbo run check",
    "check:format": "prettier --check .",
    "check:lint": "turbo run check:lint",
    "check:types": "turbo run check:types",
    "check:unused": "knip",
    "dev:web": "turbo run dev:web",
    "fix": "turbo run fix",
    "fix:format": "prettier --write .",
    "fix:lint": "turbo run fix:lint",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "knip": "^6.24.0",
    "prettier": "^3.9.5",
    "prettier-plugin-classnames": "^0.10.4",
    "prettier-plugin-merge": "^0.10.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.10.5"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.0.0"
    },
    "runtime": {
      "name": "node",
      "version": ">=24.0.0"
    }
  }
}
